#include <Adafruit_GFX.h>
#include <Adafruit_ST7789.h>
#include <SPI.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// Screen connection scheme
// VCC → 3.3V (not 5V)
// GND → GNDSCL (SCLK) → D13 (Hardware SPI Clock)
// SDA (MOSI) → D11 (Hardware SPI Data)
// RES (Reset) → D8
// DC (Data/Command) → D9
// BLK → D5

#define TFT_CS -1
#define TFT_RST 8
#define TFT_DC 9
#define TFT_BLK 5

// TFT display init 240x240
Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_DC, TFT_RST);

// Soil sensor
#define SOIL_PIN A0
const int airValue = 571;
const int waterValue = 217;

// Light sensor
#define LIGHT_PIN 2

// Temperature sensor
#define TEMPERATURE_PIN 4
OneWire oneWire(TEMPERATURE_PIN);
DallasTemperature sensors(&oneWire);

// Button
#define TOUCH_PIN 7

// Plant specific params
const int overwateredSoil = 90;
const int drySoil = 20;
const int hotTemp = 30;
const int coldTemp = 10;

// Loop and sleep mode params setup
int tick = 0;
const unsigned int msPerTick = 100;
const unsigned int ticksPerScreenUpdate = 10;
const unsigned long sleepModeTimeout = 600;  // 1 minute (msPerTick * sleepModeTimeout)
bool sleepMode = false;
unsigned long lastInteractionTime = 0;

